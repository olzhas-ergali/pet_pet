# Supabase: Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# BFF (Express): скопируйте те же URL/anon в server / .env:
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...   (для webhooks / integration_events)
# WEBHOOK_FORWARD_URL=https://your-system/hooks/orders
# INTERNAL_WEBHOOK_SECRET=random
# TELEGRAM_BOT_TOKEN=  TELEGRAM_CHAT_ID=  (опционально)

# Включить прокси на BFF (npm run dev:bff или dev:full)
# В разработке с BFF: true (npm run dev:full). Vitest подставляет false.
VITE_USE_BFF=true
# Прод: абсолютный URL API если фронт на другом origin
# VITE_API_BASE_URL=https://api.example.com

# Опционально: вход без SMS (создайте пользователя в Auth → Users с email/password)
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
